<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>ca.weblite</groupId>
    <artifactId>teavm-lambda-parent</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>TeaVM Lambda</name>
    <description>Thin library for deploying TeaVM-compiled Java applications as AWS Lambda functions</description>
    <url>https://github.com/webliteca/teavm-lambda</url>

    <licenses>
        <license>
            <name>MIT License</name>
            <url>https://opensource.org/licenses/MIT</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <developers>
        <developer>
            <id>webliteca</id>
            <name>Weblite</name>
            <organization>Weblite</organization>
            <organizationUrl>https://github.com/webliteca</organizationUrl>
        </developer>
    </developers>

    <scm>
        <connection>scm:git:git://github.com/webliteca/teavm-lambda.git</connection>
        <developerConnection>scm:git:ssh://github.com:webliteca/teavm-lambda.git</developerConnection>
        <url>https://github.com/webliteca/teavm-lambda</url>
    </scm>

    <modules>
        <module>teavm-lambda-core</module>
        <module>teavm-lambda-core-js</module>
        <module>teavm-lambda-core-jvm</module>
        <module>teavm-lambda-processor</module>
        <module>teavm-lambda-adapter-lambda</module>
        <module>teavm-lambda-adapter-lambda-jvm</module>
        <module>teavm-lambda-adapter-cloudrun</module>
        <module>teavm-lambda-adapter-httpserver</module>
        <module>teavm-lambda-db-api</module>
        <module>teavm-lambda-db</module>
        <module>teavm-lambda-db-jvm</module>
        <module>teavm-lambda-nosqldb</module>
        <module>teavm-lambda-dynamodb</module>
        <module>teavm-lambda-firestore</module>
        <module>teavm-lambda-logging</module>
        <module>teavm-lambda-sentry</module>
        <module>teavm-lambda-image-api</module>
        <module>teavm-lambda-image</module>
        <module>teavm-lambda-image-jvm</module>
        <module>teavm-lambda-auth</module>
        <module>teavm-lambda-auth-jvm</module>
        <module>teavm-lambda-demo</module>
        <module>teavm-lambda-demo-cloudrun</module>
        <module>teavm-lambda-demo-auth</module>
        <module>teavm-lambda-demo-nosqldb</module>
        <module>teavm-lambda-compression</module>
        <module>teavm-lambda-compression-jvm</module>
        <module>teavm-lambda-demo-features</module>
        <module>teavm-lambda-demo-features-lambda</module>
        <module>teavm-lambda-objectstore</module>
        <module>teavm-lambda-s3</module>
        <module>teavm-lambda-s3-jvm</module>
        <module>teavm-lambda-gcs</module>
        <module>teavm-lambda-gcs-jvm</module>
        <module>teavm-lambda-messagequeue</module>
        <module>teavm-lambda-sqs</module>
        <module>teavm-lambda-sqs-jvm</module>
        <module>teavm-lambda-pubsub</module>
        <module>teavm-lambda-pubsub-jvm</module>
        <module>teavm-lambda-demo-objectstore</module>
        <module>teavm-lambda-demo-messagequeue</module>
    </modules>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.release>21</maven.compiler.release>
        <teavm.version>0.10.2</teavm.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.teavm</groupId>
                <artifactId>teavm-classlib</artifactId>
                <version>${teavm.version}</version>
            </dependency>
            <dependency>
                <groupId>org.teavm</groupId>
                <artifactId>teavm-jso</artifactId>
                <version>${teavm.version}</version>
            </dependency>
            <dependency>
                <groupId>org.teavm</groupId>
                <artifactId>teavm-jso-apis</artifactId>
                <version>${teavm.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-core</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-core-js</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-core-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-processor</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-adapter-lambda</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-adapter-lambda-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-adapter-cloudrun</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-adapter-httpserver</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-db-api</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-db</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-db-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-nosqldb</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-dynamodb</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-firestore</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-auth</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-auth-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-image-api</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-image</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-image-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-logging</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-sentry</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-compression</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-compression-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-objectstore</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-s3</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-s3-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-gcs</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-gcs-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-messagequeue</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-sqs</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-sqs-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-pubsub</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>ca.weblite</groupId>
                <artifactId>teavm-lambda-pubsub-jvm</artifactId>
                <version>${project.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <plugins>
            <plugin>
                <groupId>org.sonatype.central</groupId>
                <artifactId>central-publishing-maven-plugin</artifactId>
                <version>0.7.0</version>
                <extensions>true</extensions>
                <configuration>
                    <publishingServerId>central</publishingServerId>
                    <autoPublish>true</autoPublish>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <id>sign-artifacts</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-source-plugin</artifactId>
                        <version>3.3.0</version>
                        <executions>
                            <execution>
                                <id>attach-sources</id>
                                <goals>
                                    <goal>jar-no-fork</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-javadoc-plugin</artifactId>
                        <version>3.6.3</version>
                        <configuration>
                            <failOnError>false</failOnError>
                            <failOnWarnings>false</failOnWarnings>
                            <doclint>none</doclint>
                        </configuration>
                        <executions>
                            <execution>
                                <id>attach-javadocs</id>
                                <goals>
                                    <goal>jar</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-gpg-plugin</artifactId>
                        <version>3.0.1</version>
                        <executions>
                            <execution>
                                <id>sign-artifacts</id>
                                <phase>verify</phase>
                                <goals>
                                    <goal>sign</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
